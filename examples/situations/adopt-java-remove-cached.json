{
  "version": 1,
  "id": "adopt-java-remove-cached",
  "workflow": "adopt",
  "description": "Adopt an existing Java project and plan removal of already tracked files that are now ignored.",
  "command": "ignorekit adopt D:/IdeaProjects/veto --preset java-gradle --remove-cached --dry-run",
  "context": {
    "targetPath": "D:/IdeaProjects/veto",
    "directoryState": "existing-non-empty",
    "gitState": "repo-root",
    "existingGitignore": ".gitignore"
  },
  "config": {
    "version": 1,
    "name": "veto",
    "preset": "java-gradle",
    "provider": {
      "name": "gitignore.io",
      "templates": ["java", "gradle", "intellij", "visualstudiocode", "windows", "macos"]
    },
    "components": ["local/env-secrets", "local/logs", "local/assistant-artifacts"],
    "custom": ["/vault/", "/audit/", "/models/", "*.gguf", "credentials.enc"]
  },
  "generation": {
    "enabled": true,
    "output": ".gitignore",
    "overwrite": false
  },
  "addons": [
    {
      "type": "removeCachedIgnoredFiles",
      "dryRun": true
    }
  ],
  "expected": {
    "writes": ["ignorekit.json", ".gitignore.preview"],
    "gitInit": "skip-existing-repo",
    "cachedRemoval": "dry-run"
  }
}

