{
  "name": "ignorekit",
  "version": "0.9.19",
  "description": "Build .gitignore files from composable components and presets",
  "keywords": [
    "gitignore",
    "generator",
    "ignore",
    "git",
    "component",
    "preset",
    "cli",
    "config",
    "cross-platform"
  ],
  "homepage": "https://github.com/MidCoard/ignorekit#readme",
  "bugs": {
    "url": "https://github.com/MidCoard/ignorekit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MidCoard/ignorekit.git"
  },
  "license": "MIT",
  "bin": {
    "ignorekit": "bin/ignorekit.js"
  },
  "files": [
    "bin/",
    "src/",
    "components/",
    "presets/"
  ],
  "exports": {
    ".": "./src/cli.js"
  },
  "scripts": {
    "list": "node bin/ignorekit.js list",
    "validate:situations": "node scripts/validate-situations.js",
    "test": "node --test test/*.test.js && npm run validate:situations",
    "test:unit": "node --test test/*.test.js",
    "prepublishOnly": "npm run test:unit && npm run validate:situations"
  },
  "engines": {
    "node": ">=18"
  }
}
