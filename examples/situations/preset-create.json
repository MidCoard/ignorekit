  },
  "config": {
    "version": 1,
    "name": "focess-service",
    "preset": "java-gradle-focess",
    "components": [],
    "custom": []
  },
  "generation": {
    "enabled": false
  },
  "addons": [],
  "expected": {
    "writes": ["presets/java-gradle-focess.json"],
    "requiresReview": true
  }
