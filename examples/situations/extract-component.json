{
  "version": 1,
  "id": "extract-component",
  "workflow": "extract",
  "description": "Extract project-specific lines from an existing .gitignore into a reusable local component draft.",
  "command": "ignorekit extract component local/focess-runtime --from D:/IdeaProjects/focess-api/.gitignore",
  "context": {
    "sourceGitignore": "D:/IdeaProjects/focess-api/.gitignore"
  },
  "extract": {
    "source": "D:/IdeaProjects/focess-api/.gitignore",
    "output": {
      "kind": "component",
      "id": "local/focess-runtime",
      "path": "components/local/focess-runtime.gitignore"
    },
    "strategy": "manual-review"
  },
  "config": {
    "version": 1,
    "name": "focess-runtime",
    "components": ["local/focess-runtime"],
    "custom": []
  },
  "generation": {
    "enabled": false
  },
  "addons": [],
  "expected": {
    "writes": ["components/local/focess-runtime.gitignore"],
    "requiresReview": true
  }
}

